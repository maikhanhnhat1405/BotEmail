# --- CẤU HÌNH SERVER EMAIL ---
# Gmail: imap.gmail.com | Outlook: outlook.office365.com
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Gmail: smtp.gmail.com | Outlook: smtp.office365.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- TÀI KHOẢN KẾT NỐI ---
# Lưu ý: Với Gmail, EMAIL_PASS phải là "App Password" (16 ký tự)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# --- CẤU HÌNH HỆ THỐNG ---
# Tên file lưu trữ các ID email đã xử lý
STORAGE_PATH=processed_ids.json